# ===========================================
# 股票數據 API 配置 (按優先級排序)
# ===========================================

# 1. Finnhub API (推薦 - 最穩定，每分鐘60次調用)
# 註冊: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# 2. Financial Modeling Prep API (基本面數據)
# 註冊: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# 3. Polygon.io API (美股專業數據)
# 註冊: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# 4. Alpha Vantage API (備用數據源)
# 註冊: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=production

# Redis Configuration
REDIS_URL=redis://localhost:6379

# CORS Configuration (for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
ENABLE_MONITORING=true
MONITOR_INTERVAL_MS=300000

# xAI Grok API Configuration
# XAI_API_BASE can be left empty to use provider default
XAI_API_KEY=
XAI_API_BASE=
XAI_MODEL=

# Authentication (Login Gate)
# Set admin credentials for /login
AUTH_USER=admin
AUTH_PASSWORD=
# Optional: Session lifetime in ms (default 12h)
SESSION_TTL_MS=43200000

# Perplexity API (LLM provider)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro